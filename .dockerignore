model/xgboost_champion.json
model/catboost_info/

# Infrastructure / Config
infra/
.env
*.csv
*.tfstate
*.tfstate.*
.terraform/

# IDE / OS
.vscode/
.idea/
__pycache__/
*.pyc
*.pyo

# Misc
*.md
*.md.resolved
*.png
*.pdf
*.npy
